{
  "poems": [
    {
      "title": "垓下歌",
      "author": "项羽",
      "dynasty": "秦末汉初",
      "lines": [
        { "text": "力拔山兮气盖世。" },
        { "text": "时不利兮骓不逝。" },
        { "text": "骓不逝兮可奈何！" },
        { "text": "虞兮虞兮奈若何！" }
      ]
    },
    {
      "title": "长歌行",
      "author": "佚名",
      "dynasty": "汉",
      "lines": [
        { "text": "青青园中葵，" },
        { "text": "朝露待日晞。" },
        { "text": "阳春布德泽，" },
        { "text": "万物生光辉。" },
        { "text": "常恐秋节至，" },
        { "text": "焜黄华叶衰。" },
        { "text": "百川东到海，" },
        { "text": "何时复西归？" },
        { "text": "少壮不努力，" },
        { "text": "老大徒伤悲！" }
      ]
    },
    {
      "title": "十五从军征",
      "author": "佚名",
      "dynasty": "汉",
      "lines": [
        { "text": "十五从军征，八十始得归。" },
        { "text": "道逢乡里人：“家中有阿谁？”" },
        { "text": "“遥看是君家，松柏冢累累。”" },
        { "text": "兔从狗窦入，雉从梁上飞。" },
        { "text": "中庭生旅谷，井上生旅葵。" },
        { "text": "舂谷持作饭，采葵持作羹。" },
        { "text": "羹饭一时熟，不知饴阿谁。" },
        { "text": "出门东向看，泪落沾我衣。" }
      ]
    },
    {
      "title": "庭中有奇树",
      "author": "佚名",
      "dynasty": "汉",
      "lines": [
        { "text": "庭中有奇树，" },
        { "text": "绿叶发华滋。" },
        { "text": "攀条折其荣，" },
        { "text": "将以遗所思。" },
        { "text": "馨香盈怀袖，" },
        { "text": "路远莫致之。" },
        { "text": "此物何足贵？" },
        { "text": "但感别经时。" }
      ]
    },
    {
      "title": "短歌行",
      "author": "曹操",
      "dynasty": "汉",
      "lines": [
        { "text": "对酒当歌，人生几何？" },
        { "text": "譬如朝露，去日苦多。" },
        { "text": "慨当以慷，忧思难忘。" },
        { "text": "何以解忧？惟有杜康。" },
        { "text": "青青子衿，悠悠我心。" },
        { "text": "但为君故，沉吟至今。" },
        { "text": "呦呦鹿鸣，食野之苹。" },
        { "text": "我有嘉宾，鼓瑟吹笙。" },
        { "text": "明明如月，何时可掇？" },
        { "text": "忧从中来，不可断绝。" },
        { "text": "越陌度阡，枉用相存。" },
        { "text": "契阔谈讌，心念旧恩。" },
        { "text": "月明星稀，乌鹊南飞。" },
        { "text": "绕树三匝，何枝可依？" },
        { "text": "山不厌高，海不厌深。" },
        { "text": "周公吐哺，天下归心。" }
      ]
    },
    {
      "title": "归园田居（其三）",
      "author": "陶渊明",
      "dynasty": "晋",
      "lines": [
        { "text": "种豆南山下，" },
        { "text": "草盛豆苗稀。" },
        { "text": "晨兴理荒秽，" },
        { "text": "带月荷锄归。" },
        { "text": "道狭草木长，" },
        { "text": "夕露沾我衣。" },
        { "text": "衣沾不足惜，" },
        { "text": "但使愿无违。" }
      ]
    },
    {
      "title": "杂诗（其一）",
      "author": "陶渊明",
      "dynasty": "晋",
      "lines": [
        { "text": "人生无根蒂，" },
        { "text": "飘如陌上尘。" },
        { "text": "分散逐风转，" },
        { "text": "此已非常身。" },
        { "text": "落地为兄弟，" },
        { "text": "何必骨肉亲！" },
        { "text": "得欢当作乐，" },
        { "text": "斗酒聚比邻。" },
        { "text": "盛年不重来，" },
        { "text": "一日难再晨。" },
        { "text": "及时当勉励，" },
        { "text": "岁月不待人。" }
      ]
    },
    {
      "title": "咏萤",
      "author": "虞世南",
      "dynasty": "唐",
      "lines": [
        { "text": "的历流光小，" },
        { "text": "飘飖弱翅轻。" },
        { "text": "恐畏无人识，" },
        { "text": "独自暗中明。" }
      ]
    },
    {
      "title": "送杜少府之任蜀州",
      "author": "王勃",
      "dynasty": "唐",
      "lines": [
        { "text": "城阙辅三秦，" },
        { "text": "风烟望五津。" },
        { "text": "与君离别意，" },
        { "text": "同是宦游人。" },
        { "text": "海内存知己，" },
        { "text": "天涯若比邻。" },
        { "text": "无为在岐路，" },
        { "text": "儿女共沾巾。" }
      ]
    },
    {
      "title": "春江花月夜",
      "author": "张若虚",
      "dynasty": "唐",
      "lines": [
        { "text": "春江潮水连海平，海上明月共潮生。" },
        { "text": "滟滟随波千万里，何处春江无月明！" },
        { "text": "江流宛转绕芳甸，月照花林皆似霰；" },
        { "text": "空里流霜不觉飞，汀上白沙看不见。" },
        { "text": "江天一色无纤尘，皎皎空中孤月轮。" },
        { "text": "江畔何人初见月？江月何年初照人？" },
        { "text": "人生代代无穷已，江月年年望相似。" },
        { "text": "不知江月待何人，但见长江送流水。" },
        { "text": "白云一片去悠悠，青枫浦上不胜愁。" },
        { "text": "谁家今夜扁舟子？何处相思明月楼？" },
        { "text": "可怜楼上月徘徊，应照离人妆镜台。" },
        { "text": "玉户帘中卷不去，捣衣砧上拂还来。" },
        { "text": "此时相望不相闻，愿逐月华流照君。" },
        { "text": "鸿雁长飞光不度，鱼龙潜跃水成文。" },
        { "text": "昨夜闲潭梦落花，可怜春半不还家。" },
        { "text": "江水流春去欲尽，江潭落月复西斜。" },
        { "text": "斜月沉沉藏海雾，碣石潇湘无限路。" },
        { "text": "不知乘月几人归，落月摇情满江树。" }
      ]
    },
    {
      "title": "送元二使安西",
      "author": "王维",
      "dynasty": "唐",
      "lines": [
        { "text": "渭城朝雨浥轻尘，" },
        { "text": "客舍青青柳色新。" },
        { "text": "劝君更尽一杯酒，" },
        { "text": "西出阳关无故人。" }
      ]
    },
    {
      "title": "送别",
      "author": "王维",
      "dynasty": "唐",
      "lines": [
        { "text": "下马饮君酒，" },
        { "text": "问君何所之？" },
        { "text": "君言不得意，" },
        { "text": "归卧南山陲。" },
        { "text": "但去莫复问，" },
        { "text": "白云无尽时。" }
      ]
    },
    {
      "title": "山中送别",
      "author": "王维",
      "dynasty": "唐",
      "lines": [
        { "text": "山中相送罢，" },
        { "text": "日暮掩柴扉。" },
        { "text": "春草明年绿，" },
        { "text": "王孙归不归？" }
      ]
    },
    {
      "title": "竹里馆",
      "author": "王维",
      "dynasty": "唐",
      "lines": [
        { "text": "独坐幽篁里，" },
        { "text": "弹琴复长啸。" },
        { "text": "深林人不知，" },
        { "text": "明月来相照。" }
      ]
    },
    {
      "title": "闺怨",
      "author": "王昌龄",
      "dynasty": "唐",
      "lines": [
        { "text": "闺中少妇不知愁，" },
        { "text": "春日凝妆上翠楼。" },
        { "text": "忽见陌头杨柳色，" },
        { "text": "悔教夫婿觅封侯。" }
      ]
    },
    {
      "title": "送友人",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        { "text": "青山横北郭，" },
        { "text": "白水绕东城。" },
        { "text": "此地一为别，" },
        { "text": "孤蓬万里征。" },
        { "text": "浮云游子意，" },
        { "text": "落日故人情。" },
        { "text": "挥手自兹去，" },
        { "text": "萧萧班马鸣。" }
      ]
    },
    {
      "title": "秋浦歌",
      "author": "李白",
      "dynasty": "唐",
      "lines": [
        { "text": "白发三千丈，" },
        { "text": "缘愁似个长。" },
        { "text": "不知明镜里，" },
        { "text": "何处得秋霜。" }
      ]
    },
    {
      "title": "黄鹤楼",
      "author": "崔颢",
      "dynasty": "唐",
      "lines": [
        { "text": "昔人已乘黄鹤去，" },
        { "text": "此地空余黄鹤楼。" },
        { "text": "黄鹤一去不复返，" },
        { "text": "白云千载空悠悠。" },
        { "text": "晴川历历汉阳树，" },
        { "text": "芳草萋萋鹦鹉洲。" },
        { "text": "日暮乡关何处是，" },
        { "text": "烟波江上使人愁。" }
      ]
    },
    {
      "title": "兵车行",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        { "text": "车辚辚，马萧萧，行人弓箭各在腰。" },
        { "text": "爷娘妻子走相送，尘埃不见咸阳桥。" },
        { "text": "牵衣顿足拦道哭，哭声直上干云霄。" },
        { "text": "道旁过者问行人，行人但云点行频。" },
        { "text": "或从十五北防河，便至四十西营田。" },
        { "text": "去时里正与裹头，归来头白还戍边。" },
        { "text": "边庭流血成海水，武皇开边意未已。" },
        { "text": "君不闻，汉家山东二百州，千村万落生荆杞。" },
        { "text": "纵有健妇把锄犁，禾生陇亩无东西。" },
        { "text": "况复秦兵耐苦战，被驱不异犬与鸡。" },
        { "text": "长者虽有问，役夫敢申恨？" },
        { "text": "且如今年冬，未休关西卒。" },
        { "text": "县官急索租，租税从何出？" },
        { "text": "信知生男恶，反是生女好。" },
        { "text": "生女犹得嫁比邻，生男埋没随百草。" },
        { "text": "君不见，青海头，古来白骨无人收。" },
        { "text": "新鬼烦冤旧鬼哭，天阴雨湿声啾啾！" }
      ]
    },
    {
      "title": "春望",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        { "text": "国破山河在，" },
        { "text": "城春草木深。" },
        { "text": "感时花溅泪，" },
        { "text": "恨别鸟惊心。" },
        { "text": "烽火连三月，" },
        { "text": "家书抵万金。" },
        { "text": "白头搔更短，" },
        { "text": "浑欲不胜簪。" }
      ]
    },
    {
      "title": "客至",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        { "text": "舍南舍北皆春水，" },
        { "text": "但见群鸥日日来。" },
        { "text": "花径不曾缘客扫，" },
        { "text": "蓬门今始为君开。" },
        { "text": "盘飧市远无兼味，" },
        { "text": "樽酒家贫只旧醅。" },
        { "text": "肯与邻翁相对饮，" },
        { "text": "隔篱呼取尽余杯。" }
      ]
    },
    {
      "title": "月夜",
      "author": "杜甫",
      "dynasty": "唐",
      "lines": [
        { "text": "今夜鄜州月，" },
        { "text": "闺中只独看。" },
        { "text": "遥怜小儿女，" },
        { "text": "未解忆长安。" },
        { "text": "香雾云鬟湿，" },
        { "text": "清辉玉臂寒。" },
        { "text": "何时倚虚幌，" },
        { "text": "双照泪痕干。" }
      ]
    },
    {
      "title": "江村即事",
      "author": "司空曙",
      "dynasty": "唐",
      "lines": [
        { "text": "钓罢归来不系船，" },
        { "text": "江村月落正堪眠。" },
        { "text": "纵然一夜风吹去，" },
        { "text": "只在芦花浅水边。" }
      ]
    },
    {
      "title": "小松",
      "author": "杜荀鹤",
      "dynasty": "唐",
      "lines": [
        { "text": "自小刺头深草里，" },
        { "text": "而今渐觉出蓬蒿。" },
        { "text": "时人不识凌云木，" },
        { "text": "直待凌云始道高。" }
      ]
    },
    {
      "title": "初春小雨",
      "author": "韩愈",
      "dynasty": "唐",
      "lines": [
        { "text": "天街小雨润如酥，" },
        { "text": "草色遥看近却无。" },
        { "text": "最是一年春好处，" },
        { "text": "绝胜烟柳满皇都。" }
      ]
    },
    {
      "title": "竹枝词（其一）",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        { "text": "杨柳青青江水平，" },
        { "text": "闻郎江上唱歌声。" },
        { "text": "东边日出西边雨，" },
        { "text": "道是无晴却有晴。" }
      ]
    },
    {
      "title": "乌衣巷",
      "author": "刘禹锡",
      "dynasty": "唐",
      "lines": [
        { "text": "朱雀桥边野草花，" },
        { "text": "乌衣巷口夕阳斜。" },
        { "text": "旧时王谢堂前燕，" },
        { "text": "飞入寻常百姓家。" }
      ]
    },
    {
      "title": "问刘十九",
      "author": "白居易",
      "dynasty": "唐",
      "lines": [
        { "text": "绿蚁新醅酒，" },
        { "text": "红泥小火炉。" },
        { "text": "晚来天欲雪，" },
        { "text": "能饮一杯无？" }
      ]
    },
    {
      "title": "近试上张籍水部",
      "author": "朱庆馀",
      "dynasty": "唐",
      "lines": [
        { "text": "洞房昨夜停红烛，" },
        { "text": "待晓堂前拜舅姑。" },
        { "text": "妆罢低声问夫婿，" },
        { "text": "画眉深浅入时无？" }
      ]
    },
    {
      "title": "金缕衣",
      "author": "杜秋娘",
      "dynasty": "唐",
      "lines": [
        { "text": "劝君莫惜金缕衣，" },
        { "text": "劝君惜取少年时。" },
        { "text": "花开堪折直须折，" },
        { "text": "莫待无花空折枝。" }
      ]
    },
    {
      "title": "赠别",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        { "text": "多情却似总无情，" },
        { "text": "唯觉樽前笑不成。" },
        { "text": "蜡烛有心还惜别，" },
        { "text": "替人垂泪到天明。" }
      ]
    },
    {
      "title": "泊秦淮",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        { "text": "烟笼寒水月笼沙，" },
        { "text": "夜泊秦淮近酒家。" },
        { "text": "商女不知亡国恨，" },
        { "text": "隔江犹唱后庭花。" }
      ]
    },
    {
      "title": "秋夕",
      "author": "杜牧",
      "dynasty": "唐",
      "lines": [
        { "text": "银烛秋光冷画屏，" },
        { "text": "轻罗小扇扑流萤。" },
        { "text": "天阶夜色凉如水，" },
        { "text": "卧看牵牛织女星。" }
      ]
    },
    {
      "title": "登乐游原",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": [
        { "text": "向晚意不适，" },
        { "text": "驱车登古原。" },
        { "text": "夕阳无限好，" },
        { "text": "只是近黄昏。" }
      ]
    },
    {
      "title": "夜雨寄北",
      "author": "李商隐",
      "dynasty": "唐",
      "lines": [
        { "text": "君问归期未有期，" },
        { "text": "巴山夜雨涨秋池。" },
        { "text": "何当共剪西窗烛，" },
        { "text": "却话巴山夜雨时。" }
      ]
    },
    {
      "title": "官仓鼠",
      "author": "曹邺",
      "dynasty": "唐",
      "lines": [
        { "text": "官仓老鼠大如斗，" },
        { "text": "见人开仓亦不走。" },
        { "text": "健儿无粮百姓饿，" },
        { "text": "谁遣朝朝入君口？" }
      ]
    },
    {
      "title": "华山",
      "author": "寇准",
      "dynasty": "宋",
      "lines": [
        { "text": "只有天在上，" },
        { "text": "更无山与齐。" },
        { "text": "举头红日近，" },
        { "text": "回首白云低。" }
      ]
    },
    {
      "title": "画眉鸟",
      "author": "欧阳修",
      "dynasty": "宋",
      "lines": [
        { "text": "百啭千声随意移，" },
        { "text": "山花红紫树高低。" },
        { "text": "始知锁向金笼听，" },
        { "text": "不及林间自在啼。" }
      ]
    },
    {
      "title": "淮中晚泊犊头",
      "author": "苏舜钦",
      "dynasty": "宋",
      "lines": [
        { "text": "春阴垂野草青青，" },
        { "text": "时有幽花一树明。" },
        { "text": "晚泊孤舟古祠下，" },
        { "text": "满川风雨看潮生。" }
      ]
    },
    {
      "title": "登飞来峰",
      "author": "王安石",
      "dynasty": "宋",
      "lines": [
        { "text": "飞来峰上千寻塔，" },
        { "text": "闻说鸡鸣见日升。" },
        { "text": "不畏浮云遮望眼，" },
        { "text": "自缘身在最高层。" }
      ]
    },
    {
      "title": "花影",
      "author": "苏轼",
      "dynasty": "宋",
      "lines": [
        { "text": "重重叠叠上瑶台，" },
        { "text": "几度呼童扫不开。" },
        { "text": "刚被太阳收拾去，" },
        { "text": "却教明月送将来。" }
      ]
    },
    {
      "title": "病牛",
      "author": "李纲",
      "dynasty": "宋",
      "lines": [
        { "text": "耕犁千亩实千箱，" },
        { "text": "力尽筋疲谁复伤？" },
        { "text": "但得众生皆得饱，" },
        { "text": "不辞羸病卧残阳。" }
      ]
    },
    {
      "title": "月儿弯弯照九州",
      "author": "佚名",
      "dynasty": "宋",
      "lines": [
        { "text": "月儿弯弯照九州，" },
        { "text": "几家欢乐几家愁。" },
        { "text": "几家夫妇同罗帐，" },
        { "text": "几家飘散在他州。" }
      ]
    },
    {
      "title": "约客",
      "author": "赵师秀",
      "dynasty": "宋",
      "lines": [
        { "text": "黄梅时节家家雨，" },
        { "text": "青草池塘处处蛙。" },
        { "text": "有约不来过夜半，" },
        { "text": "闲敲棋子落灯花。" }
      ]
    },
    {
      "title": "游园不值",
      "author": "叶绍翁",
      "dynasty": "宋",
      "lines": [
        { "text": "应怜屐齿印苍苔，" },
        { "text": "小扣柴扉久不开。" },
        { "text": "春色满园关不住，" },
        { "text": "一枝红杏出墙来。" }
      ]
    },
    {
      "title": "过零丁洋",
      "author": "文天祥",
      "dynasty": "宋",
      "lines": [
        { "text": "辛苦遭逢起一经，" },
        { "text": "干戈寥落四周星。" },
        { "text": "山河破碎风飘絮，" },
        { "text": "身世浮沉雨打萍。" },
        { "text": "惶恐滩头说惶恐，" },
        { "text": "零丁洋里叹零丁。" },
        { "text": "人生自古谁无死，" },
        { "text": "留取丹心照汗青。" }
      ]
    },
    {
      "title": "素梅（其五十六）",
      "author": "王冕",
      "dynasty": "元",
      "lines": [
        { "text": "冰雪林中著此身，" },
        { "text": "不同桃李混芳尘。" },
        { "text": "忽然一夜清香发，" },
        { "text": "散作乾坤万里春。" }
      ]
    },
    {
      "title": "风鸢图诗（其一）",
      "author": "徐渭",
      "dynasty": "明",
      "lines": [
        { "text": "柳条搓线絮搓棉，" },
        { "text": "搓够千寻放纸鸢。" },
        { "text": "消得春风多少力，" },
        { "text": "带将儿辈上青天。" }
      ]
    },
    {
      "title": "木兰辞",
      "author": "佚名",
      "dynasty": "南北朝",
      "lines": [
        { "text": "唧唧复唧唧，木兰当户织。" },
        { "text": "不闻机杼声，唯闻女叹息。" },
        { "text": "问女何所思，问女何所忆。" },
        { "text": "女亦无所思，女亦无所忆。" },
        { "text": "昨夜见军帖，可汗大点兵，" },
        { "text": "军书十二卷，卷卷有爷名。" },
        { "text": "阿爷无大儿，木兰无长兄，" },
        { "text": "愿为市鞍马，从此替爷征。" },
        { "text": "东市买骏马，西市买鞍鞯，" },
        { "text": "南市买辔头，北市买长鞭。" },
        { "text": "旦辞爷娘去，暮宿黄河边，" },
        { "text": "不闻爷娘唤女声，但闻黄河流水鸣溅溅。" },
        { "text": "旦辞黄河去，暮至黑山头，" },
        { "text": "不闻爷娘唤女声，但闻燕山胡骑鸣啾啾。" },
        { "text": "万里赴戎机，关山度若飞。" },
        { "text": "朔气传金柝，寒光照铁衣。" },
        { "text": "将军百战死，壮士十年归。" },
        { "text": "归来见天子，天子坐明堂。" },
        { "text": "策勋十二转，赏赐百千强。" },
        { "text": "可汗问所欲，木兰不用尚书郎，" },
        { "text": "愿驰千里足，送儿还故乡。" },
        { "text": "爷娘闻女来，出郭相扶将；" },
        { "text": "阿姊闻妹来，当户理红妆；" },
        { "text": "小弟闻姊来，磨刀霍霍向猪羊。" },
        { "text": "开我东阁门，坐我西阁床。" },
        { "text": "脱我战时袍，著我旧时裳。" },
        { "text": "当窗理云鬓，对镜帖花黄。" },
        { "text": "出门看火伴，火伴皆惊忙：" },
        { "text": "同行十二年，不知木兰是女郎。" },
        { "text": "雄兔脚扑朔，雌兔眼迷离；" },
        { "text": "双兔傍地走，安能辨我是雄雌？" }
      ]
    }
  ]
}
